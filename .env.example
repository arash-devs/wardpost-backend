# Copy this file to `.env` and fill in your real values.
# Never commit `.env` to git — only `.env.example`.

# Edgegap API token (from app.edgegap.com → User Settings → Tokens)
EDGEGAP_TOKEN=your-token-here

# The request_id of the deployment you want Wardpost to monitor
# (from your Edgegap dashboard after deploying)
EDGEGAP_REQUEST_ID=your-request-id-here

# How often to poll Edgegap's Status API, in seconds.
# 30s is safe under the 20 req/s rate limit even with many deployments.
POLL_INTERVAL_SECONDS=30
